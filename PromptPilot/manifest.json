{
  "manifest_version": 3,
  "name": "PromptPilot — AI Prompt Enhancer",
  "short_name": "PromptPilot",
  "description": "Instantly enhance your AI prompts. PromptPilot detects your topic, enriches context, and rewrites your prompt into an expert-level query — one click.",
  "version": "1.0.0",
  "author": "PromptPilot",

  "icons": {
    "16":  "assets/icons/icon-16.png",
    "32":  "assets/icons/icon-32.png",
    "48":  "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16":  "assets/icons/icon-16.png",
      "32":  "assets/icons/icon-32.png",
      "48":  "assets/icons/icon-48.png",
      "128": "assets/icons/icon-128.png"
    },
    "default_title": "PromptPilot"
  },

  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://perplexity.ai/*",
        "https://www.perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://poe.com/*"
      ],
      "js": ["content/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],

  "permissions": [
    "storage",
    "alarms",
    "activeTab",
    "clipboardWrite"
  ],

  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://perplexity.ai/*",
    "https://www.perplexity.ai/*",
    "https://copilot.microsoft.com/*",
    "https://poe.com/*",
    "https://api.openai.com/*",
    "https://api.anthropic.com/*",
    "https://api.groq.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],

  "web_accessible_resources": [
    {
      "resources": ["assets/icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
